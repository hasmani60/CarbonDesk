NODE_ENV=development
PORT=5001
MONGODB_URI=mongodb://localhost:27017/carbon-accounting
JWT_SECRET=your-secret-key-for-testing
CLIENT_URL=http://localhost:5173

# Company Operations (Keep Secret!)
COMPANY_JWT_SECRET=your-super-secret-company-key-change-this-immediately
COMPANY_OPERATOR_EMAIL=admin@carbontrack-company.com

# Multi-Tenant Configuration
ENABLE_MULTI_TENANT=true
DEFAULT_SUBSCRIPTION_TIER=standard
DEFAULT_MAX_USERS_PER_ORG=50
DEFAULT_MAX_STORAGE_GB=10