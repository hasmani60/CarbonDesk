# ==========================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ==========================================
# Copy this file to .env.production and update values

# ==========================================
# APPLICATION SETTINGS
# ==========================================
NODE_ENV=production
PORT=5001
CLIENT_URL=https://your-domain.com

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# MongoDB Connection (Primary Database)
MONGODB_URI=mongodb://username:password@localhost:27017/carbon_accounting?authSource=admin

# MongoDB Atlas Connection (Alternative - Recommended for Production)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/carbon_accounting?retryWrites=true&w=majority

# ==========================================
# JWT CONFIGURATION
# ==========================================
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your-super-secure-jwt-secret-change-this-in-production
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# ==========================================
# COMPANY OPERATIONS
# ==========================================
COMPANY_JWT_SECRET=your-super-secure-company-jwt-secret-change-this
COMPANY_JWT_EXPIRE=24h

# ==========================================
# EMAIL CONFIGURATION (Optional)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
FROM_EMAIL=noreply@your-domain.com
FROM_NAME=Carbon Accounting System

# ==========================================
# SECURITY
# ==========================================
# CORS Origins (comma-separated)
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_ADMIN_MAX=500
RATE_LIMIT_COMPANY_MAX=200

# ==========================================
# FILE UPLOAD
# ==========================================
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=info
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=5242880
LOG_MAX_FILES=5

# ==========================================
# REDIS (Optional - for session storage)
# ==========================================
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# SESSION_SECRET=your-session-secret-change-this

# ==========================================
# MONITORING (Optional)
# ==========================================
# SENTRY_DSN=https://your-sentry-dsn
# NEW_RELIC_LICENSE_KEY=your-new-relic-key
# NEW_RELIC_APP_NAME=Carbon Accounting API

# ==========================================
# BACKUP CONFIGURATION (Optional)
# ==========================================
# BACKUP_ENABLED=true
# BACKUP_SCHEDULE=0 2 * * *
# BACKUP_PATH=./backups
# BACKUP_RETENTION_DAYS=30

# ==========================================
# FEATURE FLAGS
# ==========================================
ENABLE_SWAGGER=false
ENABLE_PROFILING=false
ENABLE_DEBUG_MODE=false

# ==========================================
# AI REPORT GENERATION (n8n)
# ==========================================
# Option A — JWT: POST/PATCH with Authorization: Bearer <token> (admin or analyst).
# Option B — Webhook secret: set N8N_REPORT_API_SECRET and send header X-Report-Secret
# (same value). Body must include organisationId. Omit Bearer on those requests.
N8N_REPORT_API_SECRET=your-long-random-secret
