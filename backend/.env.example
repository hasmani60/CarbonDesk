# ==========================================
# CARBON ACCOUNTING SYSTEM - CONFIGURATION
# ==========================================
# Copy this file to .env and update values

# ==========================================
# APPLICATION SETTINGS
# ==========================================
NODE_ENV=development
PORT=5001
CLIENT_URL=http://localhost:5173

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/carbon_accounting_dev

# For MongoDB Atlas (Cloud)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/carbon_accounting?retryWrites=true&w=majority

# ==========================================
# JWT CONFIGURATION
# ==========================================
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your-development-jwt-secret-change-in-production
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# ==========================================
# COMPANY OPERATIONS
# ==========================================
COMPANY_JWT_SECRET=your-development-company-jwt-secret-change-in-production
COMPANY_JWT_EXPIRE=24h
COMPANY_OPERATOR_EMAIL=admin@carbontrack-company.com

# ==========================================
# MULTI-TENANT CONFIGURATION
# ==========================================
ENABLE_MULTI_TENANT=true
DEFAULT_SUBSCRIPTION_TIER=standard
DEFAULT_MAX_USERS_PER_ORG=50
DEFAULT_MAX_STORAGE_GB=10

# ==========================================
# EMAIL CONFIGURATION (Optional)
# ==========================================
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=enquiries@naturemarksystems.com
SMTP_PASS=NatureMark@1452
FROM_EMAIL=enquiries@naturemarksystems.com
FROM_NAME=CarbonDesk

# --- Email notifications (product events → inbox) ---
# Set to true after SMTP works; requires code hooks for each event you care about.
ENABLE_EMAIL_NOTIFICATIONS=true

# --- Email verification (optional; requires SMTP for real delivery) ---
# 1) New registrations get a verify link (no login token until verified if you use strict flow)
EMAIL_VERIFICATION_ON_REGISTER=true
# 2) Block login until email is verified (login page can "Resend verification")
REQUIRE_EMAIL_VERIFICATION=true

# Password reset email link lifetime (ms), default 3600000 (1 hour)
# PASSWORD_RESET_EXPIRE_MS=3600000

# Optional: secure POST /health/email-diagnostic on Render (no Shell needed); use a long random value
# RENDER_EMAIL_DIAGNOSTIC_SECRET=

# ==========================================
# SECURITY
# ==========================================
# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_ADMIN_MAX=500
RATE_LIMIT_COMPANY_MAX=200

# ==========================================
# FILE UPLOAD
# ==========================================
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=debug
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=5242880
LOG_MAX_FILES=5

# ==========================================
# REDIS (Optional - for session storage)
# ==========================================
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# SESSION_SECRET=your-session-secret-change-this

# ==========================================
# FEATURE FLAGS
# ==========================================
ENABLE_SWAGGER=true
ENABLE_PROFILING=false
ENABLE_DEBUG_MODE=true
