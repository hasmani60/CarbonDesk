# ==========================================
# CARBON ACCOUNTING SYSTEM - CONFIGURATION
# ==========================================
# Copy this file to .env and update values

# ==========================================
# APPLICATION SETTINGS
# ==========================================
NODE_ENV=development
PORT=5001
CLIENT_URL=http://localhost:5173

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/carbon_accounting_dev

# For MongoDB Atlas (Cloud)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/carbon_accounting?retryWrites=true&w=majority

# ==========================================
# JWT CONFIGURATION
# ==========================================
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your-development-jwt-secret-change-in-production
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# ==========================================
# COMPANY OPERATIONS
# ==========================================
COMPANY_JWT_SECRET=your-development-company-jwt-secret-change-in-production
COMPANY_JWT_EXPIRE=24h
COMPANY_OPERATOR_EMAIL=admin@carbontrack-company.com

# ==========================================
# MULTI-TENANT CONFIGURATION
# ==========================================
ENABLE_MULTI_TENANT=true
DEFAULT_SUBSCRIPTION_TIER=standard
DEFAULT_MAX_USERS_PER_ORG=50
DEFAULT_MAX_STORAGE_GB=10

# ==========================================
# EMAIL CONFIGURATION (Optional)
# ==========================================
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=enquiries@naturemarksystems.com
SMTP_PASS=NatureMark@1452
FROM_EMAIL=enquiries@naturemarksystems.com
FROM_NAME=CarbonDesk

# Render FREE web services block outbound SMTP (ports 25/465/587). Use Resend over HTTPS instead:
# RESEND_API_KEY=re_xxxx
# RESEND_FROM=CarbonDesk <noreply@yourverifieddomain.com>
# In Render, do not wrap the whole value in extra "quotes" or use Word-style “smart” quotes.
# (No wrapping quotes in Render—use plain Name <email> or email only. Smart quotes break Resend.)
# Until you verify a domain at resend.com/domains, Resend only delivers TO the account owner email
# (e.g. naturemarksystems@gmail.com)—not to app users. Verify DNS → use From on that domain → any recipient.

# --- Email notifications (product events → inbox) ---
# Set to true after SMTP works; requires code hooks for each event you care about.
ENABLE_EMAIL_NOTIFICATIONS=true

# --- Email verification (optional; requires SMTP for real delivery) ---
# 1) New registrations get a verify link (no login token until verified if you use strict flow)
EMAIL_VERIFICATION_ON_REGISTER=true
# 2) Block login until email is verified (login page can "Resend verification")
REQUIRE_EMAIL_VERIFICATION=true

# Password reset link lifetime — use ONE of:
# PASSWORD_RESET_EXPIRE_MINUTES=60
# PASSWORD_RESET_EXPIRE_MS=3600000
# (If both unset, default is 60 minutes.)

# New org subscription term (days until subscription_expires_at)
# SUBSCRIPTION_DEFAULT_TERM_DAYS=365
# Email super admin when subscription ends within this many days (default 60)
# SUBSCRIPTION_RENEWAL_REMINDER_DAYS=60
# How often the server checks for renewal reminders (ms), default 6 hours
# SUBSCRIPTION_REMINDER_JOB_INTERVAL_MS=21600000

# Per-tier user caps (optional overrides; defaults basic=10, standard=50, premium=200)
# TIER_BASIC_MAX_USERS=10
# TIER_STANDARD_MAX_USERS=50
# TIER_PREMIUM_MAX_USERS=200

# Optional: secure POST /health/email-diagnostic on Render (no Shell needed); use a long random value
# RENDER_EMAIL_DIAGNOSTIC_SECRET=

# ==========================================
# SECURITY
# ==========================================
# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_ADMIN_MAX=500
RATE_LIMIT_COMPANY_MAX=200

# ==========================================
# FILE UPLOAD
# ==========================================
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=debug
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=5242880
LOG_MAX_FILES=5

# ==========================================
# REDIS (Optional - for session storage)
# ==========================================
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# SESSION_SECRET=your-session-secret-change-this

# ==========================================
# FEATURE FLAGS
# ==========================================
ENABLE_SWAGGER=true
ENABLE_PROFILING=false
ENABLE_DEBUG_MODE=true

# ==========================================
# ROAD / LOCATION SEARCH
# ==========================================
# photon = Komoot Photon (default, works on Render shared IPs)
# nominatim = OpenStreetMap only (strict 1 req/s — often 429 on production)
# auto = Photon first, then Nominatim
# GEOCODER_SEARCH=photon
#
# Required if using Nominatim — app name + contact email
# NOMINATIM_USER_AGENT=CarbonDesk/1.0 (your-org; contact@yourcompany.com)
#
# Production frontend (Vercel) — also set on Render:
# CLIENT_URL=https://carbon-desk.vercel.app
# CORS_ORIGINS=https://carbon-desk.vercel.app
