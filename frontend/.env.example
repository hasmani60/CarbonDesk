# ==========================================
# CARBON ACCOUNTING - FRONTEND CONFIGURATION
# ==========================================
# Copy this file to .env or .env.production

# ==========================================
# API CONFIGURATION
# ==========================================
VITE_API_URL=http://localhost:5001/api

# For production, use your domain:
# VITE_API_URL=https://your-domain.com/api

# ==========================================
# APPLICATION SETTINGS
# ==========================================
VITE_APP_NAME=Carbon Accounting System
VITE_APP_VERSION=2.0.0

# ==========================================
# FEATURES (Optional)
# ==========================================
# VITE_ENABLE_ANALYTICS=false
# VITE_ENABLE_SENTRY=false
# VITE_SENTRY_DSN=your-sentry-dsn

# ==========================================
# THEME (Optional)
# ==========================================
# VITE_DEFAULT_THEME=light

# ==========================================
# AI REPORT (n8n webhook — no API keys here)
# ==========================================
# VITE_N8N_REPORT_WEBHOOK_URL=https://your-n8n.example.com/webhook/generate-carbon-report
